# =============================================================================
# ledger-bridge environment configuration (EXAMPLE)
# Copy to `.env` and fill in real values. NEVER commit a real `.env`.
# Values marked "TODO: confirm" are unverified assumptions — pin them down
# before production use (see README "Open questions").
# =============================================================================

# ---- Runtime -----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
HOST=0.0.0.0
PORT=8443

# ---- TLS (required outside development) --------------------------------------
# The service is TLS-only. In development you may set TLS_ENABLED=false to run
# plain HTTP locally; in production TLS_ENABLED must be true.
TLS_ENABLED=false
TLS_CERT_PATH=./crypto/tls/server-cert.pem
TLS_KEY_PATH=./crypto/tls/server-key.pem

# ---- Redis (idempotency store + BullMQ queue) --------------------------------
REDIS_URL=redis://localhost:6379
# Default TTL (seconds) for idempotency keys.
IDEMPOTENCY_TTL_SECONDS=86400

# ---- Rate limiting -----------------------------------------------------------
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute

# ---- Supabase member JWT verification ----------------------------------------
# Member-facing browser requests carry a Supabase-issued JWT.
# TODO: confirm the actual Supabase project ref / issuer / JWKS URL.
SUPABASE_JWKS_URL=https://TODO-project-ref.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://TODO-project-ref.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# ---- OAuth 2.0 (centuriesmutual.com Developer Portal partners) ---------------
# TODO: confirm the authorization server issuer + JWKS for partner tokens.
DEVELOPER_OAUTH_ISSUER=https://developers.centuriesmutual.com
DEVELOPER_OAUTH_JWKS_URL=https://developers.centuriesmutual.com/.well-known/jwks.json
DEVELOPER_OAUTH_AUDIENCE=ledger-bridge

# ---- Server-to-server API keys -----------------------------------------------
# Comma-separated list of "keyId:sha256hex:scope1|scope2" entries.
# Store only SHA-256 hashes of keys here, never the raw key.
# Example: partnerA:9f86d0...:rewards:read|wellness:read
API_KEYS=

# ---- Inbound webhook HMAC secrets (each source has its own) -------------------
# Never trust an inbound webhook payload before verifying its signature.
WEBHOOK_SECRET_WEARABLE=replace-me-wearable-hmac-secret
WEBHOOK_SECRET_AD_NETWORK=replace-me-adnetwork-hmac-secret
WEBHOOK_SECRET_USDC=replace-me-usdc-hmac-secret

# ---- Hyperledger Fabric Gateway ----------------------------------------------
# Connection to the peer's gRPC gateway. Network infra lives in `centuries-ledger`;
# this service only connects as a client.
FABRIC_GATEWAY_ENDPOINT=localhost:7051
FABRIC_GATEWAY_HOST_ALIAS=peer0.org1.example.com
FABRIC_MSP_ID=Org1MSP
FABRIC_CHANNEL=centuries-channel
FABRIC_CHAINCODE_NAME=centuries
# MSP identity material for the bridge's gateway client identity.
FABRIC_TLS_CERT_PATH=./crypto/peer/tls-ca-cert.pem
FABRIC_CERT_PATH=./crypto/user/cert.pem
FABRIC_PRIVATE_KEY_PATH=./crypto/user/private-key.pem

# ---- USDC settlement provider (Wintergarden payouts) -------------------------
# CONFIRMED: USDC custody/settlement is handled by Circle Internet Group.
# Provider stays swappable behind USDCSettlementProvider. DO NOT hardcode real
# keys — put them in your local .env (gitignored), never here.
USDC_PROVIDER=circle
# Sandbox base; use https://api.circle.com in production.
USDC_PROVIDER_API_BASE=https://api-sandbox.circle.com
# Full Circle API key string (e.g. "TEST_API_KEY:<id>:<secret>").
USDC_PROVIDER_API_KEY=set-in-your-local-env-or-production-secret-store
# Circle wallet id (Circle Mint) that holds USDC and funds the transfers.
USDC_SOURCE_WALLET_ID=TODO-confirm-circle-source-wallet-id
# Public chain settlement happens on (TODO: confirm — Base? Solana? Ethereum?)
USDC_SETTLEMENT_CHAIN=base-sepolia

# ---- Wearable data aggregator ------------------------------------------------
# MyBrothersKeeper syncs many devices via a single aggregator.
# TODO: confirm actual vendor (Terra / Spike / Vital / ...) and payload shape.
WEARABLE_AGGREGATOR_API_BASE=https://TODO-confirm-aggregator.example.com
WEARABLE_AGGREGATOR_API_KEY=TODO-confirm-aggregator-key
